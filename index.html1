<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>VIP Hunter</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#050508;--surface:#0e0e14;--surface2:#16161f;--border:#1e1e2e;
  --gold:#f5c842;--gold2:#ffd96a;--gold3:#c9973a;
  --red:#e63946;--text:#f0eeff;--muted:#7a7a9a;
  --glow:rgba(245,200,66,.18);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;min-height:100vh;overflow-x:hidden;cursor:default;}

/* BG EFFECTS */
.bg-grid{position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(rgba(245,200,66,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(245,200,66,.03) 1px,transparent 1px);
  background-size:60px 60px;}
.bg-glow{position:fixed;top:-200px;left:50%;transform:translateX(-50%);width:800px;height:500px;
  background:radial-gradient(ellipse,rgba(245,200,66,.08) 0%,transparent 70%);pointer-events:none;z-index:0;}
.bg-glow2{position:fixed;bottom:-100px;right:-100px;width:500px;height:500px;
  background:radial-gradient(ellipse,rgba(230,57,70,.06) 0%,transparent 70%);pointer-events:none;z-index:0;}

/* HEADER */
.topbar{position:sticky;top:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;height:62px;
  background:rgba(5,5,8,.85);backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(245,200,66,.1);}
.topbar-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo-crown{font-size:1.5rem;filter:drop-shadow(0 0 8px rgba(245,200,66,.6));}
.logo-name{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:3px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.channel-btn{display:inline-flex;align-items:center;gap:7px;
  background:rgba(245,200,66,.08);border:1px solid rgba(245,200,66,.2);
  color:var(--gold);font-size:.8rem;font-weight:600;padding:7px 16px;
  border-radius:100px;text-decoration:none;transition:all .2s;letter-spacing:.5px;}
.channel-btn:hover{background:rgba(245,200,66,.15);border-color:var(--gold);box-shadow:0 0 20px var(--glow);}
.admin-pill{display:none;align-items:center;gap:8px;
  background:rgba(245,200,66,.1);border:1px solid rgba(245,200,66,.25);
  color:var(--gold);font-size:.75rem;font-weight:700;padding:6px 14px;
  border-radius:100px;letter-spacing:.5px;}
.admin-pill.show{display:inline-flex;}
.logout-btn{background:rgba(230,57,70,.15);border:1px solid rgba(230,57,70,.3);
  color:var(--red);font-size:.7rem;font-weight:700;padding:3px 9px;
  border-radius:100px;cursor:pointer;transition:all .2s;font-family:'Outfit',sans-serif;}
.logout-btn:hover{background:rgba(230,57,70,.3);}
.key-btn{width:38px;height:38px;border-radius:50%;
  background:rgba(245,200,66,.08);border:1px solid rgba(245,200,66,.2);
  color:var(--gold);font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.key-btn:hover{background:var(--gold);color:#000;box-shadow:0 0 20px var(--glow);}

/* HERO */
.hero{position:relative;z-index:1;text-align:center;padding:90px 20px 70px;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;
  background:rgba(245,200,66,.08);border:1px solid rgba(245,200,66,.15);
  color:var(--gold);font-size:.72rem;font-weight:700;letter-spacing:3px;
  padding:6px 18px;border-radius:100px;margin-bottom:28px;text-transform:uppercase;
  animation:fadeUp .6s ease both;}
.hero-eyebrow::before{content:'✦';font-size:.6rem;}
.hero-eyebrow::after{content:'✦';font-size:.6rem;}
.hero h1{font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3.5rem,10vw,7rem);letter-spacing:4px;line-height:.95;
  margin-bottom:20px;animation:fadeUp .6s .08s ease both;}
.hero h1 .line1{display:block;color:#fff;}
.hero h1 .line2{display:block;
  background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 50%,var(--gold3) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  filter:drop-shadow(0 0 30px rgba(245,200,66,.3));}
.hero-sub{color:var(--muted);font-size:1rem;max-width:480px;margin:0 auto 40px;line-height:1.7;
  animation:fadeUp .6s .16s ease both;}
.hero-cta{display:inline-flex;align-items:center;gap:10px;
  background:linear-gradient(135deg,var(--gold),var(--gold3));
  color:#000;font-weight:800;font-size:1rem;padding:16px 36px;
  border-radius:12px;text-decoration:none;letter-spacing:.5px;
  box-shadow:0 4px 30px rgba(245,200,66,.35);transition:all .25s;
  animation:fadeUp .6s .24s ease both;}
.hero-cta:hover{transform:translateY(-3px);box-shadow:0 8px 40px rgba(245,200,66,.5);}
.hero-cta svg{transition:transform .2s;}
.hero-cta:hover svg{transform:translateX(4px);}

/* TRUST BAR */
.trust-bar{position:relative;z-index:1;display:flex;justify-content:center;
  gap:0;max-width:600px;margin:0 auto 70px;padding:0 20px;
  animation:fadeUp .6s .3s ease both;}
.trust-item{flex:1;text-align:center;padding:20px 10px;
  background:var(--surface);border:1px solid var(--border);}
.trust-item:first-child{border-radius:14px 0 0 14px;}
.trust-item:last-child{border-radius:0 14px 14px 0;}
.trust-item+.trust-item{border-left:none;}
.trust-val{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:2px;
  color:var(--gold);display:block;line-height:1;}
.trust-lbl{font-size:.65rem;color:var(--muted);font-weight:600;letter-spacing:2px;text-transform:uppercase;margin-top:4px;}

/* SECTION */
.section{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:0 20px 80px;}
.sec-header{text-align:center;margin-bottom:48px;}
.sec-tag{display:inline-block;background:rgba(245,200,66,.08);border:1px solid rgba(245,200,66,.15);
  color:var(--gold);font-size:.65rem;font-weight:700;letter-spacing:3px;
  padding:4px 14px;border-radius:100px;margin-bottom:14px;text-transform:uppercase;}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,5vw,3.2rem);
  letter-spacing:3px;color:#fff;margin-bottom:10px;}
.sec-sub{color:var(--muted);font-size:.9rem;max-width:440px;margin:0 auto;line-height:1.7;}

/* VIP GRID */
.vip-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:22px;}
@media(max-width:640px){.vip-grid{grid-template-columns:1fr;}}

/* VIP CARD */
.vcard{background:var(--surface);border:1px solid var(--border);border-radius:20px;
  overflow:hidden;transition:all .3s;animation:cardIn .5s ease both;
  display:flex;flex-direction:column;position:relative;cursor:pointer;}
.vcard::after{content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(245,200,66,.06),transparent 60%);
  opacity:0;transition:opacity .3s;pointer-events:none;}
.vcard:hover{transform:translateY(-6px);border-color:rgba(245,200,66,.4);
  box-shadow:0 20px 60px rgba(245,200,66,.12);}
.vcard:hover::after{opacity:1;}

.vcard-img{width:100%;aspect-ratio:16/9;background:var(--surface2);
  display:flex;align-items:center;justify-content:center;font-size:4rem;
  flex-shrink:0;overflow:hidden;position:relative;}
.vcard-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
.vcard:hover .vcard-img img{transform:scale(1.05);}
.vcard-img.no-img{background:linear-gradient(135deg,var(--surface2),#1a1a10);}

.vcard-tier{position:absolute;top:12px;left:12px;
  font-size:.62rem;font-weight:800;padding:4px 10px;border-radius:100px;
  letter-spacing:1.5px;text-transform:uppercase;}
.tier-gold{background:linear-gradient(135deg,var(--gold),var(--gold3));color:#000;}
.tier-silver{background:linear-gradient(135deg,#c0c0c0,#888);color:#000;}
.tier-diamond{background:linear-gradient(135deg,#a8edea,#fed6e3);color:#000;}
.tier-custom{background:rgba(245,200,66,.2);border:1px solid rgba(245,200,66,.4);color:var(--gold);}

.vcard-body{padding:20px;flex:1;display:flex;flex-direction:column;}
.vcard-name{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:2px;
  color:#fff;margin-bottom:8px;line-height:1;}
.vcard-desc{font-size:.83rem;color:var(--muted);line-height:1.6;margin-bottom:14px;flex:1;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}

.vcard-feats{display:flex;flex-direction:column;gap:5px;margin-bottom:18px;}
.feat-row{display:flex;align-items:center;gap:7px;font-size:.78rem;color:var(--muted);}
.feat-row::before{content:'✦';color:var(--gold);font-size:.55rem;flex-shrink:0;}

.vcard-footer{display:flex;align-items:center;justify-content:space-between;gap:10px;
  border-top:1px solid var(--border);padding-top:16px;margin-top:auto;}
.price-area .price-lbl{font-size:.58rem;color:var(--muted);font-weight:600;letter-spacing:1.5px;text-transform:uppercase;}
.price-val{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:1px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;}
.price-per{font-size:.68rem;color:var(--muted);font-weight:500;}

.buy-btn{display:inline-flex;align-items:center;gap:7px;
  background:linear-gradient(135deg,var(--gold),var(--gold3));
  color:#000;font-weight:800;font-size:.82rem;padding:11px 18px;
  border-radius:10px;text-decoration:none;white-space:nowrap;
  transition:all .2s;box-shadow:0 4px 16px rgba(245,200,66,.25);border:none;cursor:pointer;}
.buy-btn:hover{transform:scale(1.05);box-shadow:0 6px 24px rgba(245,200,66,.4);}

/* ADMIN ACTIONS */
.admin-actions{display:none;gap:6px;padding:10px 20px;border-top:1px solid var(--border);}
body.admin-mode .admin-actions{display:flex;}
.btn-edit,.btn-del{flex:1;display:inline-flex;align-items:center;justify-content:center;gap:4px;
  font-family:'Outfit',sans-serif;font-size:.72rem;font-weight:700;
  padding:7px;border-radius:8px;cursor:pointer;border:1px solid;transition:all .2s;}
.btn-edit{background:rgba(245,200,66,.08);border-color:rgba(245,200,66,.2);color:var(--gold);}
.btn-edit:hover{background:var(--gold);color:#000;}
.btn-del{background:rgba(230,57,70,.08);border-color:rgba(230,57,70,.2);color:var(--red);}
.btn-del:hover{background:var(--red);color:#fff;}

/* ADD CARD */
.add-card{background:transparent;border:2px dashed var(--border);border-radius:20px;
  display:none;flex-direction:column;align-items:center;justify-content:center;
  gap:12px;cursor:pointer;transition:all .3s;min-height:300px;text-align:center;padding:24px;}
body.admin-mode .add-card{display:flex;}
.add-card:hover{border-color:rgba(245,200,66,.4);background:rgba(245,200,66,.03);}
.add-card-icon{font-size:2.8rem;opacity:.25;transition:opacity .2s;}
.add-card:hover .add-card-icon{opacity:.8;}
.add-card-text{color:var(--muted);font-size:.9rem;font-weight:600;}

/* SPINNER */
.spinner-wrap{grid-column:1/-1;text-align:center;padding:80px 20px;}
.spinner{width:40px;height:40px;border:3px solid var(--border);
  border-top-color:var(--gold);border-radius:50%;
  animation:spin .8s linear infinite;margin:0 auto 16px;}
@keyframes spin{to{transform:rotate(360deg);}}

/* OVERLAY */
.overlay{position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.9);
  backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:center;
  padding:16px;opacity:0;pointer-events:none;transition:opacity .3s;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--surface);border:1px solid rgba(245,200,66,.15);
  border-radius:22px;padding:34px;width:100%;max-width:520px;
  max-height:92vh;overflow-y:auto;transform:translateY(20px) scale(.97);transition:transform .3s;position:relative;}
.overlay.open .modal{transform:translateY(0) scale(1);}
.modal-close{position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:50%;
  background:var(--surface2);border:1px solid var(--border);color:var(--muted);
  font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.modal-close:hover{background:var(--red);color:#fff;border-color:var(--red);}
.modal h2{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:2px;
  color:var(--gold);margin-bottom:4px;}
.modal-sub{color:var(--muted);font-size:.83rem;margin-bottom:24px;}

.fg{margin-bottom:14px;}
.fg label{display:block;font-size:.7rem;font-weight:700;color:var(--muted);
  letter-spacing:1.5px;text-transform:uppercase;margin-bottom:7px;}
.fg input,.fg textarea,.fg select{width:100%;background:var(--surface2);
  border:1px solid var(--border);color:var(--text);font-family:'Outfit',sans-serif;
  font-size:.88rem;padding:11px 14px;border-radius:10px;outline:none;transition:border-color .2s;}
.fg input:focus,.fg textarea:focus,.fg select:focus{border-color:rgba(245,200,66,.5);}
.fg textarea{resize:vertical;min-height:80px;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.btn-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px;}
.save-btn{background:linear-gradient(135deg,var(--gold),var(--gold3));color:#000;
  border:none;font-family:'Outfit',sans-serif;font-weight:800;font-size:.9rem;
  padding:13px;border-radius:10px;cursor:pointer;transition:all .2s;
  box-shadow:0 4px 20px rgba(245,200,66,.3);}
.save-btn:hover{box-shadow:0 6px 28px rgba(245,200,66,.5);transform:translateY(-1px);}
.save-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.cancel-btn{background:var(--surface2);border:1px solid var(--border);color:var(--muted);
  font-family:'Outfit',sans-serif;font-weight:700;font-size:.9rem;
  padding:13px;border-radius:10px;cursor:pointer;transition:all .2s;}
.cancel-btn:hover{border-color:var(--gold);color:var(--text);}

/* IMG UPLOAD */
.img-upload{width:100%;aspect-ratio:16/7;border:2px dashed var(--border);
  border-radius:10px;background:var(--surface2);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:8px;cursor:pointer;transition:all .2s;overflow:hidden;position:relative;}
.img-upload:hover{border-color:rgba(245,200,66,.4);}
.img-upload img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0;}
.img-upload .up-icon{font-size:2rem;opacity:.3;z-index:1;}
.img-upload .up-hint{font-size:.78rem;color:var(--muted);text-align:center;z-index:1;}
#fileInput{display:none;}

/* LOGIN */
.lock-icon{font-size:3rem;text-align:center;margin-bottom:12px;}
.pw-wrap{position:relative;}
.pw-wrap input{padding-right:44px;}
.pw-eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);
  background:none;border:none;color:var(--muted);cursor:pointer;font-size:1rem;padding:0;}
.login-err{color:var(--red);font-size:.78rem;font-weight:600;margin-top:8px;display:none;text-align:center;}
.login-err.show{display:block;}
.del-icon{font-size:2.5rem;text-align:center;margin-bottom:10px;}
.del-btn{background:var(--red);color:#fff;border:none;font-family:'Outfit',sans-serif;
  font-weight:700;font-size:.9rem;padding:13px;border-radius:10px;cursor:pointer;}
.del-btn:disabled{opacity:.5;cursor:not-allowed;}

/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);
  background:var(--gold);color:#000;font-weight:700;padding:11px 22px;
  border-radius:100px;z-index:9999;transition:transform .3s;
  font-size:.85rem;white-space:nowrap;pointer-events:none;}
.toast.show{transform:translateX(-50%) translateY(0);}
.toast.err{background:var(--red);color:#fff;}
.toast.ok{background:#22c55e;color:#fff;}

/* FOOTER */
footer{position:relative;z-index:1;text-align:center;padding:40px 20px 60px;
  border-top:1px solid var(--border);color:var(--muted);font-size:.8rem;}
footer a{color:var(--gold);text-decoration:none;}
.footer-logo{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:3px;
  color:var(--gold);margin-bottom:8px;}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
@keyframes cardIn{from{opacity:0;transform:translateY(16px) scale(.98);}to{opacity:1;transform:translateY(0) scale(1);}}
@media(max-width:560px){
  .frow,.btn-row{grid-template-columns:1fr;}
  .trust-bar{flex-wrap:wrap;}
  .trust-item{flex:1 1 45%;}
  .trust-item:first-child{border-radius:14px 0 0 0;}
  .trust-item:nth-child(2){border-radius:0 14px 0 0;border-left:1px solid var(--border);}
  .trust-item:nth-child(3){border-radius:0 0 0 14px;border-top:none;}
  .trust-item:last-child{border-radius:0 0 14px 0;border-left:1px solid var(--border);border-top:none;}
  .trust-item+.trust-item{border-left:none;}
}
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="bg-glow"></div>
<div class="bg-glow2"></div>

<!-- TOPBAR -->
<nav class="topbar">
  <a href="#" class="topbar-logo">
    <span class="logo-crown">👑</span>
    <span class="logo-name">VIP HUNTER</span>
  </a>
  <div class="topbar-right">
    <a href="https://t.me/testy" target="_blank" class="channel-btn" id="channelBtn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.927 13.01 5.07 12.12c-.652-.204-.664-.652.136-.964l11.17-4.307c.54-.196 1.016.12.518 1.372z"/></svg>
      Channel
    </a>
    <div class="admin-pill" id="adminPill">
      👑 ADMIN
      <button class="logout-btn" id="logoutBtn">Keluar</button>
    </div>
    <button class="key-btn" id="keyBtn" title="Admin Login">🔑</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-eyebrow">Exclusive Membership Access</div>
  <h1>
    <span class="line1">BERGABUNG DENGAN</span>
    <span class="line2">VIP HUNTER</span>
  </h1>
  <p class="hero-sub">Dapatkan akses eksklusif ke semua fitur premium. Pilih paket VIP terbaikmu dan mulai berburu sekarang.</p>
  <a href="#paket" class="hero-cta">
    Lihat Paket VIP
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </a>
</section>

<!-- TRUST BAR -->
<div class="trust-bar" id="trustBar">
  <div class="trust-item"><span class="trust-val" id="tProduk">0</span><span class="trust-lbl">Paket VIP</span></div>
  <div class="trust-item"><span class="trust-val">24/7</span><span class="trust-lbl">Support</span></div>
  <div class="trust-item"><span class="trust-val">100%</span><span class="trust-lbl">Terpercaya</span></div>
  <div class="trust-item"><span class="trust-val">⚡</span><span class="trust-lbl">Aktivasi Cepat</span></div>
</div>

<!-- VIP SECTION -->
<section class="section" id="paket">
  <div class="sec-header">
    <div class="sec-tag">✦ Pilih Paketmu ✦</div>
    <div class="sec-title">PAKET VIP MEMBERSHIP</div>
    <p class="sec-sub">Semua paket memberikan akses penuh ke fitur hunter terbaik</p>
  </div>
  <div class="vip-grid" id="grid">
    <div class="spinner-wrap"><div class="spinner"></div><p style="color:var(--muted)">Memuat paket VIP...</p></div>
  </div>
</section>

<!-- OVERLAY: LOGIN -->
<div class="overlay" id="loginModal">
  <div class="modal" style="max-width:360px;">
    <div class="lock-icon">🔐</div>
    <h2 style="text-align:center;font-size:1.5rem;">ADMIN LOGIN</h2>
    <p class="modal-sub" style="text-align:center;">Masukkan password untuk kelola paket VIP.</p>
    <div class="fg">
      <label>Password</label>
      <div class="pw-wrap">
        <input type="password" id="pwInput" placeholder="••••••••"/>
        <button class="pw-eye" id="pwEye" type="button">👁️</button>
      </div>
    </div>
    <div class="login-err" id="loginErr">❌ Password salah!</div>
    <button class="save-btn" id="loginBtn" style="width:100%;margin-top:14px;">🔓 Masuk</button>
  </div>
</div>

<!-- OVERLAY: TAMBAH/EDIT VIP -->
<div class="overlay" id="prodModal">
  <div class="modal">
    <button class="modal-close" id="closeProdModal">✕</button>
    <h2 id="modalTitle">TAMBAH VIP</h2>
    <p class="modal-sub" id="modalSub">Isi data paket VIP. Langsung terlihat semua member.</p>
    <input type="hidden" id="fId"/>

    <div class="fg">
      <label>Gambar / Banner</label>
      <div class="img-upload" id="imgUpload">
        <div class="up-icon">🖼️</div>
        <div class="up-hint">Klik untuk upload gambar<br/><small>Dikompres otomatis</small></div>
        <img id="imgPreview" style="display:none;"/>
      </div>
      <input type="file" id="fileInput" accept="image/*"/>
    </div>

    <div class="frow">
      <div class="fg"><label>Nama Paket *</label><input type="text" id="fName" placeholder="VIP Gold"/></div>
      <div class="fg"><label>Tier / Badge</label>
        <select id="fTier">
          <option value="tier-gold">⭐ Gold</option>
          <option value="tier-silver">🥈 Silver</option>
          <option value="tier-diamond">💎 Diamond</option>
          <option value="tier-custom">✦ Custom</option>
        </select>
      </div>
    </div>
    <div class="frow">
      <div class="fg"><label>Harga *</label><input type="text" id="fPrice" placeholder="50.000"/></div>
      <div class="fg"><label>Per (bulan/tahun/dll)</label><input type="text" id="fPer" placeholder="/ bulan"/></div>
    </div>
    <div class="fg"><label>Deskripsi *</label><textarea id="fDesc" placeholder="Deskripsi singkat paket VIP ini..."></textarea></div>
    <div class="fg"><label>Fitur (satu per baris)</label>
      <textarea id="fFeats" placeholder="Akses semua channel premium&#10;Bot hunter 24/7&#10;Support prioritas&#10;Update setiap hari" style="min-height:110px;"></textarea>
    </div>
    <div class="fg"><label>Username Bot Telegram *</label>
      <input type="text" id="fBot" placeholder="viphunter_xbot (tanpa @)" value="viphunter_xbot"/>
    </div>
    <div class="fg"><label>Start Parameter (untuk bedakan paket)</label>
      <input type="text" id="fStart" placeholder="vip_gold / vip_silver / vip_diamond"/>
    </div>
    <div class="btn-row">
      <button class="cancel-btn" id="cancelProd">Batal</button>
      <button class="save-btn" id="saveProd">💾 Simpan</button>
    </div>
  </div>
</div>

<!-- OVERLAY: HAPUS -->
<div class="overlay" id="delModal">
  <div class="modal" style="max-width:340px;text-align:center;">
    <div class="del-icon">🗑️</div>
    <h2 style="font-size:1.4rem;">HAPUS PAKET?</h2>
    <p class="modal-sub" id="delSub" style="margin-bottom:20px;"></p>
    <div class="btn-row">
      <button class="cancel-btn" id="cancelDel">Batal</button>
      <button class="del-btn" id="confirmDel">🗑️ Hapus</button>
    </div>
  </div>
</div>

<footer>
  <div class="footer-logo">👑 VIP HUNTER</div>
  <p>Bergabung di channel kami: <a href="https://t.me/testy" id="footerChannel" target="_blank">@testy</a></p>
  <p style="margin-top:6px;font-size:.7rem;opacity:.4;">Powered by JSONBin.io · Admin login: klik 🔑 di pojok kanan atas</p>
</footer>
<div class="toast" id="toast"></div>

<script>
// ══════════════════════════════════════════
//  ⚙️  CONFIG
// ══════════════════════════════════════════
var CONFIG = {
  adminPassword:  'Malik10_',         // ← GANTI PASSWORD
  channelUsername:'@listterbaru',          // ← username channel
  channelUrl:     'https://t.me/listterbaru', // ← link channel
};

var JSONBIN = {
  API_KEY: '$2a$10$PTkXAZ0qkDQVlglJA5mqf.l3M49P3JE3p9rwCPf/WUcl8McY9sNQq',
  BIN_ID:  '69aa4790ae596e708f643003',
};
// ══════════════════════════════════════════

var BASE_URL    = 'https://api.jsonbin.io/v3/b';
var isAdmin     = false;
var pendingDelId= null;
var isEditMode  = false;
var uploadedImg = '';
var allVIP      = [];

// ── UTILS ──
function toast(msg,type){
  var t=document.getElementById('toast');
  t.textContent=msg; t.className='toast show'+(type?' '+type:'');
  clearTimeout(t._t); t._t=setTimeout(function(){t.className='toast';},3500);
}
function openModal(id){ document.getElementById(id).classList.add('open'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }

// ── LINKS ──
document.getElementById('channelBtn').href   = CONFIG.channelUrl;
document.getElementById('footerChannel').href = CONFIG.channelUrl;
document.getElementById('footerChannel').textContent = CONFIG.channelUsername;

// ── KOMPRES GAMBAR ──
function compressImg(file,cb){
  var reader=new FileReader();
  reader.onload=function(e){
    var img=new Image();
    img.onload=function(){
      var MAX=600, w=img.width, h=img.height;
      if(w>h){if(w>MAX){h=Math.round(h*MAX/w);w=MAX;}}
      else{if(h>MAX){w=Math.round(w*MAX/h);h=MAX;}}
      var c=document.createElement('canvas');
      c.width=w;c.height=h;
      c.getContext('2d').drawImage(img,0,0,w,h);
      cb(c.toDataURL('image/jpeg',.65));
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(file);
}

// ── JSONBIN ──
async function loadVIP(){
  if(JSONBIN.BIN_ID==='GANTI_BIN_ID_VIP'){
    document.getElementById('grid').innerHTML=
      '<div style="grid-column:1/-1;text-align:center;padding:60px 20px;">'+
      '<div style="font-size:2.5rem;margin-bottom:16px">⚙️</div>'+
      '<p style="color:var(--gold);font-weight:600;margin-bottom:8px">JSONBin belum dikonfigurasi</p>'+
      '<p style="color:var(--muted);font-size:.85rem">Buat bin baru di jsonbin.io lalu isi BIN_ID di CONFIG dalam file HTML ini.</p></div>';
    document.getElementById('tProduk').textContent='0';
    return;
  }
  try{
    var res=await fetch(BASE_URL+'/'+JSONBIN.BIN_ID+'/latest',{
      headers:{'X-Master-Key':JSONBIN.API_KEY}
    });
    if(!res.ok){var e=await res.json();throw new Error(e.message||res.status);}
    var data=await res.json();
    allVIP=(data.record&&data.record.vip)?data.record.vip:[];
    renderAll();
  }catch(e){
    document.getElementById('grid').innerHTML=
      '<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--red)">'+
      '❌ Gagal memuat: '+e.message+'</div>';
  }
}

async function saveVIP(){
  var res=await fetch(BASE_URL+'/'+JSONBIN.BIN_ID,{
    method:'PUT',
    headers:{'Content-Type':'application/json','X-Master-Key':JSONBIN.API_KEY},
    body:JSON.stringify({vip:allVIP})
  });
  if(!res.ok){var e=await res.json();throw new Error(e.message||res.status);}
}

// ── RENDER ──
function renderAll(){
  document.getElementById('tProduk').textContent=allVIP.length;
  renderGrid();
}

function tierLabel(t){
  var map={'tier-gold':'⭐ Gold','tier-silver':'🥈 Silver','tier-diamond':'💎 Diamond','tier-custom':'✦ Custom'};
  return map[t]||'✦ VIP';
}

function renderGrid(){
  var grid=document.getElementById('grid');
  grid.innerHTML='';

  if(allVIP.length===0){
    grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--muted)">'+
      '<div style="font-size:3rem;margin-bottom:12px">👑</div>'+
      '<p>'+(isAdmin?'Belum ada paket VIP. Klik ➕ untuk tambah!':'Paket VIP segera hadir.')+'</p></div>';
  }

  allVIP.forEach(function(p,i){
    var card=document.createElement('div');
    card.className='vcard';
    card.style.animationDelay=(i*0.06)+'s';

    var imgHtml=p.img
      ?'<div class="vcard-img"><img src="'+p.img+'" alt="'+p.name+'"/></div>'
      :'<div class="vcard-img no-img" style="font-size:4rem;">👑</div>';

    var featsHtml=(p.features||[]).map(function(f){
      return '<div class="feat-row">'+f+'</div>';
    }).join('');

    var botName=p.bot||'viphunter_xbot';
    var startParam=p.start||'vip';
    var botLink='https://t.me/'+botName+'?start='+startParam;

    card.innerHTML=
      imgHtml+
      '<div class="vcard-tier '+(p.tier||'tier-gold')+'">'+tierLabel(p.tier)+'</div>'+
      '<div class="vcard-body">'+
        '<div class="vcard-name">'+p.name+'</div>'+
        '<div class="vcard-desc">'+p.description+'</div>'+
        (featsHtml?'<div class="vcard-feats">'+featsHtml+'</div>':'')+
        '<div class="vcard-footer">'+
          '<div class="price-area">'+
            '<div class="price-lbl">Harga</div>'+
            '<div class="price-val">'+p.price+'</div>'+
            '<div class="price-per">'+(p.per||'/ bulan')+'</div>'+
          '</div>'+
          '<a href="'+botLink+'" target="_blank" class="buy-btn">'+
            '👑 Beli VIP'+
          '</a>'+
        '</div>'+
      '</div>'+
      '<div class="admin-actions">'+
        '<button class="btn-edit" data-id="'+p.id+'">✏️ Edit</button>'+
        '<button class="btn-del" data-id="'+p.id+'" data-name="'+p.name+'">🗑️ Hapus</button>'+
      '</div>';

    // klik card (selain tombol) → buka bot
    card.addEventListener('click',function(e){
      if(!e.target.closest('.admin-actions')&&!e.target.closest('.buy-btn')){
        window.open(botLink,'_blank');
      }
    });

    grid.appendChild(card);
  });

  // Add card
  var addCard=document.createElement('div');
  addCard.className='add-card';
  addCard.innerHTML='<div class="add-card-icon">➕</div><div class="add-card-text">Tambah Paket VIP Baru</div>';
  addCard.onclick=function(){openAddModal();};
  grid.appendChild(addCard);

  grid.querySelectorAll('.btn-edit').forEach(function(btn){
    btn.addEventListener('click',function(e){e.stopPropagation();openEditModal(btn.getAttribute('data-id'));});
  });
  grid.querySelectorAll('.btn-del').forEach(function(btn){
    btn.addEventListener('click',function(e){
      e.stopPropagation();
      pendingDelId=btn.getAttribute('data-id');
      document.getElementById('delSub').innerHTML='Paket <strong style="color:var(--gold)">'+btn.getAttribute('data-name')+'</strong> akan dihapus permanen.';
      openModal('delModal');
    });
  });
}

// ── IMAGE UPLOAD ──
document.getElementById('imgUpload').addEventListener('click',function(){document.getElementById('fileInput').click();});
document.getElementById('fileInput').addEventListener('change',function(e){
  var file=e.target.files[0];
  if(!file) return;
  compressImg(file,function(dataUrl){
    uploadedImg=dataUrl;
    var prev=document.getElementById('imgPreview');
    prev.src=dataUrl; prev.style.display='block';
    document.getElementById('imgUpload').querySelector('.up-icon').style.display='none';
    document.getElementById('imgUpload').querySelector('.up-hint').style.display='none';
  });
});
function resetImg(){
  uploadedImg='';
  document.getElementById('imgPreview').src='';
  document.getElementById('imgPreview').style.display='none';
  document.getElementById('imgUpload').querySelector('.up-icon').style.display='block';
  document.getElementById('imgUpload').querySelector('.up-hint').style.display='block';
  document.getElementById('fileInput').value='';
}

// ── FORM ──
function clearForm(){
  ['fId','fName','fDesc','fFeats','fPrice','fPer','fStart'].forEach(function(id){document.getElementById(id).value='';});
  document.getElementById('fBot').value='viphunter_xbot';
  document.getElementById('fTier').value='tier-gold';
  resetImg();
}

function openAddModal(){
  isEditMode=false; clearForm();
  document.getElementById('modalTitle').textContent='TAMBAH VIP';
  document.getElementById('modalSub').textContent='Paket baru langsung terlihat semua pengunjung.';
  document.getElementById('saveProd').textContent='💾 Simpan Paket';
  openModal('prodModal');
}

function openEditModal(id){
  var p=allVIP.find(function(x){return x.id===id;});
  if(!p) return;
  isEditMode=true; clearForm();
  document.getElementById('fId').value=p.id;
  document.getElementById('fName').value=p.name;
  document.getElementById('fTier').value=p.tier||'tier-gold';
  document.getElementById('fPrice').value=p.price;
  document.getElementById('fPer').value=p.per||'';
  document.getElementById('fDesc').value=p.description;
  document.getElementById('fFeats').value=(p.features||[]).join('\n');
  document.getElementById('fBot').value=p.bot||'';
  document.getElementById('fStart').value=p.start||'';
  if(p.img){
    uploadedImg=p.img;
    var prev=document.getElementById('imgPreview');
    prev.src=p.img; prev.style.display='block';
    document.getElementById('imgUpload').querySelector('.up-icon').style.display='none';
    document.getElementById('imgUpload').querySelector('.up-hint').style.display='none';
  }
  document.getElementById('modalTitle').textContent='EDIT PAKET';
  document.getElementById('modalSub').textContent='Ubah data paket VIP lalu simpan.';
  document.getElementById('saveProd').textContent='💾 Simpan Perubahan';
  openModal('prodModal');
}

// ── SAVE ──
document.getElementById('saveProd').addEventListener('click',async function(){
  var name=document.getElementById('fName').value.trim();
  var desc=document.getElementById('fDesc').value.trim();
  var bot=document.getElementById('fBot').value.trim();
  if(!name||!desc||!bot){toast('❌ Nama, deskripsi & bot wajib diisi!','err');return;}
  var btn=document.getElementById('saveProd');
  btn.disabled=true; btn.textContent='⏳ Menyimpan...';

  var featsRaw=document.getElementById('fFeats').value.trim();
  var data={
    name,
    tier:document.getElementById('fTier').value,
    price:document.getElementById('fPrice').value.trim()||'0',
    per:document.getElementById('fPer').value.trim()||'/ bulan',
    description:desc,
    features:featsRaw?featsRaw.split('\n').map(function(f){return f.trim();}).filter(Boolean):[],
    bot:bot.replace('@',''),
    start:document.getElementById('fStart').value.trim(),
    img:uploadedImg,
  };

  if(isEditMode){
    var id=document.getElementById('fId').value;
    allVIP=allVIP.map(function(p){return p.id===id?Object.assign({},p,data):p;});
  } else {
    data.id='vip_'+Date.now();
    allVIP.push(data);
  }

  try{
    await saveVIP();
    toast('✅ "'+name+'" berhasil '+(isEditMode?'diperbarui':'ditambahkan')+'!','ok');
    closeModal('prodModal'); renderAll();
  }catch(e){
    toast('❌ Gagal simpan: '+e.message,'err');
    if(!isEditMode) allVIP.pop();
  }
  btn.disabled=false; btn.textContent=isEditMode?'💾 Simpan Perubahan':'💾 Simpan Paket';
});

// ── HAPUS ──
document.getElementById('confirmDel').addEventListener('click',async function(){
  if(!pendingDelId) return;
  var btn=document.getElementById('confirmDel');
  btn.disabled=true; btn.textContent='⏳...';
  var prev=allVIP.slice();
  allVIP=allVIP.filter(function(p){return p.id!==pendingDelId;});
  try{
    await saveVIP();
    toast('🗑️ Paket berhasil dihapus');
    pendingDelId=null; closeModal('delModal'); renderAll();
  }catch(e){allVIP=prev;toast('❌ Gagal hapus: '+e.message,'err');}
  btn.disabled=false; btn.textContent='🗑️ Hapus';
});

// ── MODAL CLOSE ──
document.getElementById('cancelDel').addEventListener('click',function(){closeModal('delModal');});
document.getElementById('delModal').addEventListener('click',function(e){if(e.target.id==='delModal')closeModal('delModal');});
document.getElementById('closeProdModal').addEventListener('click',function(){closeModal('prodModal');});
document.getElementById('cancelProd').addEventListener('click',function(){closeModal('prodModal');});
document.getElementById('prodModal').addEventListener('click',function(e){if(e.target.id==='prodModal')closeModal('prodModal');});
document.getElementById('loginModal').addEventListener('click',function(e){if(e.target.id==='loginModal')closeModal('loginModal');});

// ── ADMIN ──
function setAdmin(on){
  isAdmin=on;
  document.body.classList.toggle('admin-mode',on);
  document.getElementById('adminPill').classList.toggle('show',on);
  document.getElementById('keyBtn').textContent=on?'➕':'🔑';
  document.getElementById('keyBtn').title=on?'Tambah Paket':'Admin Login';
  renderGrid();
}
document.getElementById('keyBtn').addEventListener('click',function(){
  if(isAdmin){openAddModal();}
  else{openModal('loginModal');setTimeout(function(){document.getElementById('pwInput').focus();},150);}
});
function doLogin(){
  var pw=document.getElementById('pwInput').value;
  if(pw===CONFIG.adminPassword){
    document.getElementById('loginErr').classList.remove('show');
    document.getElementById('pwInput').value='';
    closeModal('loginModal'); setAdmin(true);
    toast('👑 Selamat datang, Admin!','ok');
  }else{
    document.getElementById('loginErr').classList.add('show');
    document.getElementById('pwInput').value='';
    document.getElementById('pwInput').focus();
  }
}
document.getElementById('loginBtn').addEventListener('click',doLogin);
document.getElementById('pwInput').addEventListener('keydown',function(e){if(e.key==='Enter')doLogin();});
document.getElementById('pwEye').addEventListener('click',function(){
  var i=document.getElementById('pwInput');
  i.type=i.type==='password'?'text':'password';
});
document.getElementById('logoutBtn').addEventListener('click',function(){setAdmin(false);toast('👋 Keluar dari mode admin');});

// ── BOOT ──
loadVIP();
</script>
</body>
</html>
